<script src="../scripts/locations.js"></script>





<div class="flex-start-start flex-wrap basic-padding" style="padding-top: 0;">
{@|apply contactPopup.block}
{@|apply contactUsWindshieldQuote.block}
{.repeated section items}

  {@|apply Locations/mapGrid.block}
{.or}

  <!-- no items means no blog posts -->
  <div id="noResults" class="flex-center-start" style="display: none; padding: 0 25px 50px;">
          <p>No results for selected filters.</p>
          <button id="filterReset" class="location-tag"><a class="no-link-styling" href="/locations">Reset filters?</a></button>
        </div>

{.end}
</div>
